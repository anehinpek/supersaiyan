transform: translateY(-1px);
}
.faq-section summary {
color: #3f3f3f;
cursor: pointer;
font-size: 12px;
font-weight: 700;
position: relative;
padding-right: 46px;
line-height: 1.55;
list-style: none;
}
.faq-section summary::-webkit-details-marker {
display: none;
}
.faq-section summary::after {
content: "+";
position: absolute;
right: 0;
top: 50%;
transform: translateY(-50%);
width: 28px;
height: 28px;
display: flex;
align-items: center;
justify-content: center;
border-radius: 50%;
background: #e8e8e8;
border: 1px solid rgba(255,255,255,0.16);
color: #f2f2f2;
font-weight: 700;
}
.faq-section[open] summary::after {
content: "-";
}
.faq-section p {
color: #5f5f5f;
