<script>

  $("#f-form").submit(function () {
    var formData = {
      name: $("#name1").val(),
      email: $("#email1").val(),
      form_name: $("#form_name1").val(),
    };
    
    $.ajax({
      type: "POST",
      url: "data_submit.php",
      data: formData,
      dataType: "json",
      encode: true,
      beforeSend:function(){
          $('.btn_submit_App1').attr("disabled","disabled");
          $('#f-form').css("opacity",".5");
        },
    }).done(function (data) {
      if(data == 1){
        alert('Submit Successfully');
        $('#f-form').css("opacity","");
        $(".btn_submit_App1").removeAttr("disabled");
        $("#f-form").trigger('reset');
      }else{
        alert('Something went wrong');
      }
    });

    event.preventDefault();
  });

</script>

