      $this->crec = intval(CommonFunctions::replaceChars($_GET["crec"], 0));
    } else {
      $this->crec = 0;
    }

    if (($this->crec % $this->reccnt) != 0) {
      $this->crec = $this->crec - ($this->crec % $this->reccnt);
    }

