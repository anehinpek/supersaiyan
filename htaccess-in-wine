<script type="text/javascript">
	$(document).ready(function(){  
		$('#frmParentsLogin').submit(function(){
			validateSend();
			return false;	
		});		
		$('#frmAlumniLogin').submit(function(){
			validateAlumniSend();
			return false;	
		});				
	});
	
	//ALUMNI LOGIN
	function validateAlumniSend()
	{
		if($('#email').val() != "" && $('#alumni_pwd').val() != "")
		{	
			$.post('ajax-new/ajax_alumnilogin.php', $("#frmAlumniLogin").serialize(), function(data) {	
				if (data[0].resSuccess == 1) 
				{
					window.location.href = "alumni/profile.php";					
					return false;	
				}
				else if(data[0].resSuccess == 2)
				{
					if(data[0].errtype == 'Validation')
					{
						for(i=0; i<data[0].arrError.length; i++)
						{
							$('#spn_' + data[0].arrError[i][0]).remove();		
							$("#" + data[0].arrError[i][0] ).after("<div id='spn_" + data[0].arrError[i][0] + "' class='div-spn-error'>" + data[0].arrError[i][1] + "</div>");
						}						
					}
					else{
						$('.errMsgText').html(data[0].msg);	
						$('#usrpwd').val('');
					}
					return false;
				}
				else
				{
					return false;
				}
			});
		}
	}
	function validateSend()
	{
		if($('#uname').val() != "" && $('#pwd').val() != "")
		{		
			$.post('ajax/ajax_login.php', $("#frmParentsLogin").serialize(), function(data) {						
									
				if (data[0].resSuccess == 1) 
				{
					window.location.href = "parents/studetails.php";
										
					return false;	
				}
				else if (data[0].resSuccess == 2) 
				{
					if(data[0].errtype == 'Validation')
					{
					 for(i=0; i<data[0].arrError.length; i++)
						{
							$('#spn_' + data[0].arrError[i][0]).remove();		
							$("#" + data[0].arrError[i][0] ).after("<div id='spn_" + data[0].arrError[i][0] + "' class='div-spn-error'>" + data[0].arrError[i][1] + "</div>");
						}	
					}
					else
					{
						$('.errMsgText').html(data[0].msg);	
						$('#usrpwd').val('');	
					}
					
					return false;	
				}					
				else
				{
					return false;
				}
				
			 });
		}	
	}	
</script>
