    $('.div-spn-error').remove();
    $.post('ajax/ajax_alumnilogin.php', $("#frmAlumniLogin").serialize(), function (data) {
      if (data[0].resSuccess == 1) {
        window.location.href = "alumni_profile.php";
        return false;
      } else if (data[0].resSuccess == 2) {
        if (data[0].errtype == 'Validation') {
          for (i = 0; i < data[0].arrError.length; i++) {
            $('#spn_' + data[0].arrError[i][0]).remove();
            $("#" + data[0].arrError[i][0]).after("<div id='spn_" + data[0].arrError[i][0] +
              "' class='div-spn-error'>" + data[0].arrError[i][1] + "</div>");
            //$('#' + data[0].arrError[i][0]).addClass("border-danger");		
          }
        } else {
          $('.errMsgText').html(data[0].msg);
          $('#usrpwd').val('');
        }
        return false;
      } else {
        return false;
      }
    });
